    {
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "wazuh_ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "basic",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 7 },
              { "color": "#E24D42", "value": 10 },
              { "color": "#762621", "value": 12 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rule.level" },
            "properties": [
              { "id": "displayName", "value": "Nivel" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "custom.width", "value": 80 },
              { "id": "custom.align", "value": "center" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "#EAB839", "value": 7 },
                    { "color": "#E24D42", "value": 10 },
                    { "color": "#762621", "value": 12 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rule.description" },
            "properties": [
              { "id": "displayName", "value": "Evento de Seguridad Detectado" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "@timestamp" },
            "properties": [
              { "id": "displayName", "value": "Fecha/Hora" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "agent.name" },
            "properties": [
              { "id": "displayName", "value": "Servidor" },
              { "id": "custom.width", "value": 150 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Fecha/Hora" } ]
      },
      "targets": [
        {
          "alias": "Alertas",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh_ds" },
          "metrics": [ { "id": "1", "type": "raw_data", "settings": { "size": "100" } } ],
          "query": "rule.level:>=3",
          "refId": "A",
          "timeField": "@timestamp",
          "useTimeRange": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_id": true, "_index": true, "_type": true, "agent.id": true, "agent.ip": true, "decoder.name": true, "location": true, "manager.name": true, "rule.id": true, "timestamp": true, "rule.groups": true, "rule.pci_dss": true, "rule.gdpr": true, "rule.nist_800_53": true, "rule.gpg13": true, "rule.hipaa": true, "rule.tsc": true, "input.type": true, "id": true, "rule.firedtimes": true, "data.srcip": true, "data.dstuser": true, "data.srcport": true, "predecoder.program_name": true, "predecoder.timestamp": true, "predecoder.hostname": true
            },
            "indexByName": {
              "@timestamp": 0,
              "agent.name": 1,
              "rule.level": 2,
              "rule.description": 3
            }
          }
        }
      ],
