{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Actividad del Balanceador (ALB)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Peticiones (Request Count)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [{ "expr": "aws_applicationelb_request_count_sum", "refId": "A" }]
    },
    {
      "title": "Tiempo de Respuesta (Response Time)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [{ "expr": "aws_applicationelb_target_response_time_average", "refId": "A" }]
    },
    {
      "title": "Salud de Servidores Web (Auto-Scaling)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "title": "Servidores Activos",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "targets": [{ "expr": "count(up{role=\"web\"} == 1) or vector(0)", "refId": "A" }]
    },
    {
      "title": "Carga CPU (Web Nodes)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 10 },
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{role=\"web\", mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "title": "Monitorización de Base de Datos (RDS)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "title": "RDS CPU Utilization",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [{ "expr": "aws_rds_cpuutilization_average", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100 } }
    },
    {
      "title": "RDS Conexiones Activas",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [{ "expr": "aws_rds_database_connections_average", "refId": "A" }]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["sentinel", "aws", "cloudwatch"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Sentinel - Enterprise Cloud Dashboard",
  "uid": "sentinel-cloud",
  "version": 1
}
